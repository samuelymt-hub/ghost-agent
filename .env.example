# ===== 火山引擎 Doubao 配置（真实值复制到 .env，切勿提交） =====
# 方式一：embedding 与 chat 用各自独立的 API Key（推荐，与你当前情况一致）
DOUBAO_EMBEDDING_API_KEY=your_embedding_api_key_here
DOUBAO_CHAT_API_KEY=your_chat_api_key_here

# 方式二（可选）：若两者共用一个 Key，可只填这个作为兜底；
# 上面两个专用 Key 留空时会自动回退到 DOUBAO_API_KEY。
DOUBAO_API_KEY=

# 模型 ID / 推理接入点
DOUBAO_EMBEDDING_MODEL=doubao-embedding-text-240715
DOUBAO_CHAT_MODEL=

# 火山方舟 API Base URL
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ===== Milvus 向量库配置 =====
# 开发期可使用 Milvus Lite（嵌入式，无需 Docker），填本地文件路径即可：
MILVUS_URI=./milvus_dev.db
# 若使用 Milvus standalone（Docker），改为服务地址，例如：
# MILVUS_URI=http://127.0.0.1:19530

# ===== 运行时参数（可选，留空则用 config.py 默认值） =====
TECH_STACK=python
